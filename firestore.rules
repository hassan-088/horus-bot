rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsExisting() {
      return signedIn() && resource.data.userId == request.auth.uid;
    }

    function ownsIncoming() {
      return signedIn() && request.resource.data.userId == request.auth.uid;
    }

    function bookingContractCreateValid() {
      return ownsIncoming()
        && request.resource.data.booking_id is string
        && request.resource.data.booking_source in ['website', 'mobile_app']
        && request.resource.data.payment_method == 'cash'
        && request.resource.data.payment_status == 'pay_at_counter'
        && request.resource.data.status == 'active';
    }

    function ownedCancelUpdateBase() {
      return ownsExisting()
        && ownsIncoming()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at', 'cancelled_at'])
        && request.resource.data.status == 'cancelled';
    }

    function ownedBookingCancelUpdate() {
      return ownedCancelUpdateBase()
        && resource.data.status == 'active';
    }

    function ownedMuseumTicketCancelUpdate() {
      return ownedCancelUpdateBase()
        && !(resource.data.status in ['used', 'cancelled', 'expired']);
    }

    function ownedRobotTourTicketCancelUpdate() {
      return ownedCancelUpdateBase()
        && !(resource.data.status in ['paired', 'in_progress', 'completed', 'cancelled', 'expired']);
    }

    function activeOwnedMuseumTicket(ticketId) {
      return signedIn()
        && ticketId is string
        && exists(/databases/$(database)/documents/museumTickets/$(ticketId))
        && get(/databases/$(database)/documents/museumTickets/$(ticketId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/museumTickets/$(ticketId)).data.status == 'active';
    }

    function activeOwnedRobotTourTicket(ticketId) {
      return signedIn()
        && ticketId is string
        && exists(/databases/$(database)/documents/robotTourTickets/$(ticketId))
        && get(/databases/$(database)/documents/robotTourTickets/$(ticketId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/robotTourTickets/$(ticketId)).data.status == 'active';
    }

    function validTourSessionCreate(sessionId) {
      return validFinalTourSessionCreate(sessionId) || validLegacyTourSessionCreate();
    }

    function validLegacyTourSessionCreate() {
      return ownsIncoming()
        && request.resource.data.sessionId is string
        && request.resource.data.robotId is string
        && request.resource.data.museumTicketId is string
        && request.resource.data.robotTourTicketId is string
        && activeOwnedMuseumTicket(request.resource.data.museumTicketId)
        && activeOwnedRobotTourTicket(request.resource.data.robotTourTicketId)
        && request.resource.data.status in ['ready', 'active', 'paused'];
    }

    function validFinalTourSessionCreate(sessionId) {
      return ownsIncoming()
        && request.resource.data.session_id is string
        && request.resource.data.session_id == sessionId
        && request.resource.data.robotId is string
        && request.resource.data.booking_id is string
        && request.resource.data.museum_ticket_id is string
        && request.resource.data.robot_tour_ticket_id is string
        && activeOwnedMuseumTicket(request.resource.data.museum_ticket_id)
        && activeOwnedRobotTourTicket(request.resource.data.robot_tour_ticket_id)
        && request.resource.data.status == 'paired'
        && request.resource.data.current_exhibit_id == null
        && request.resource.data.current_exhibit_index == 0
        && request.resource.data.selected_exhibits is list
        && request.resource.data.started_at == null
        && request.resource.data.completed_at == null;
    }

    function unassignedRobot() {
      return (!('active_session_id' in resource.data) || resource.data.active_session_id == null || resource.data.active_session_id == '')
        && (!('active_user_id' in resource.data) || resource.data.active_user_id == null || resource.data.active_user_id == '')
        && (!('active_robot_tour_ticket_id' in resource.data) || resource.data.active_robot_tour_ticket_id == null || resource.data.active_robot_tour_ticket_id == '');
    }

    function validFinalRobotAssign(robotId) {
      return signedIn()
        && resource.data.status == 'available'
        && unassignedRobot()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'active_session_id', 'active_user_id', 'active_robot_tour_ticket_id', 'updated_at'])
        && request.resource.data.status == 'assigned'
        && request.resource.data.active_session_id is string
        && request.resource.data.active_session_id != ''
        && request.resource.data.active_user_id == request.auth.uid
        && request.resource.data.active_robot_tour_ticket_id is string
        && request.resource.data.active_robot_tour_ticket_id != ''
        && existsAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.active_session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.active_session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.active_session_id)).data.robotId == robotId
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.active_session_id)).data.robot_tour_ticket_id == request.resource.data.active_robot_tour_ticket_id;
    }

    function validLegacyRobotPair() {
      return signedIn()
        && false;
    }

    function validRobotPair(robotId) {
      return validFinalRobotAssign(robotId) || validLegacyRobotPair();
    }

    function validRobotRelease() {
      return validFinalRobotRelease() || validLegacyRobotRelease();
    }

    function validLegacyRobotRelease() {
      return signedIn()
        && resource.data.status == 'paired'
        && resource.data.currentUserId == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'activeSessionId', 'currentUserId', 'updatedAt'])
        && request.resource.data.status == 'available'
        && request.resource.data.activeSessionId == ''
        && request.resource.data.currentUserId == '';
    }

    function validFinalRobotStart() {
      return signedIn()
        && resource.data.status == 'assigned'
        && resource.data.active_user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at'])
        && request.resource.data.status == 'in_tour';
    }

    function validFinalRobotRelease() {
      return signedIn()
        && resource.data.status in ['assigned', 'in_tour']
        && resource.data.active_user_id == request.auth.uid
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'active_session_id', 'active_user_id', 'active_robot_tour_ticket_id', 'updated_at'])
        && request.resource.data.status == 'available'
        && request.resource.data.active_session_id == null
        && request.resource.data.active_user_id == null
        && request.resource.data.active_robot_tour_ticket_id == null;
    }

    function unpairedExistingTicket() {
      return (!('paired_robot_id' in resource.data) || resource.data.paired_robot_id == null || resource.data.paired_robot_id == '')
        && (!('session_id' in resource.data) || resource.data.session_id == null || resource.data.session_id == '');
    }

    function validRobotTourTicketPairUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && resource.data.status == 'active'
        && unpairedExistingTicket()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'paired_robot_id', 'session_id', 'paired_at', 'updated_at'])
        && request.resource.data.status == 'paired'
        && request.resource.data.paired_robot_id is string
        && request.resource.data.paired_robot_id != ''
        && request.resource.data.session_id is string
        && request.resource.data.session_id != ''
        && existsAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(request.resource.data.session_id)).data.robotId == request.resource.data.paired_robot_id
        && existsAfter(/databases/$(database)/documents/robots/$(request.resource.data.paired_robot_id))
        && getAfter(/databases/$(database)/documents/robots/$(request.resource.data.paired_robot_id)).data.active_session_id == request.resource.data.session_id
        && getAfter(/databases/$(database)/documents/robots/$(request.resource.data.paired_robot_id)).data.active_user_id == request.auth.uid
        && getAfter(/databases/$(database)/documents/robots/$(request.resource.data.paired_robot_id)).data.active_robot_tour_ticket_id == ticketId;
    }

    function validRobotTourTicketStartUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && resource.data.status == 'paired'
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at'])
        && request.resource.data.status == 'in_progress'
        && existsAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.status == 'active';
    }

    function validRobotTourTicketCompleteUpdate(ticketId) {
      return ownsExisting()
        && ownsIncoming()
        && resource.data.status in ['paired', 'in_progress']
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['status', 'updated_at'])
        && request.resource.data.status == 'completed'
        && existsAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id))
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.userId == request.auth.uid
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.robot_tour_ticket_id == ticketId
        && getAfter(/databases/$(database)/documents/tourSessions/$(resource.data.session_id)).data.status == 'completed';
    }

    function validTourSessionOwnerUpdate() {
      return ownsExisting()
        && ownsIncoming()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly([
            'status',
            'current_exhibit_id',
            'current_exhibit_index',
            'started_at',
            'completed_at',
            'updated_at',
            'robotState',
            'visitedExhibitIds',
            'commandStatus',
            'lastCommandId',
            'lastCommandType',
            'lastCommandError',
            'lastCommandAt',
            'lastAckAt',
            'lastRobotEvent',
            'lastRobotEventAt',
            'mqttEnabled',
            'robotConnectionState'
          ])
        && request.resource.data.status in ['paired', 'active', 'paused', 'completed', 'cancelled'];
    }

    match /users/{userId} {
      allow read, update: if signedIn() && userId == request.auth.uid;
      allow create: if signedIn() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /bookings/{bookingId} {
      allow read: if ownsExisting();
      allow create: if bookingContractCreateValid();
      allow update: if ownedBookingCancelUpdate();
      allow delete: if false;
    }

    match /museumTickets/{ticketId} {
      allow read: if ownsExisting();
      allow create: if bookingContractCreateValid();
      allow update: if ownedMuseumTicketCancelUpdate();
      allow delete: if false;
    }

    match /robotTourTickets/{ticketId} {
      allow read: if ownsExisting();
      allow create: if bookingContractCreateValid();
      allow update: if ownedRobotTourTicketCancelUpdate()
        || validRobotTourTicketPairUpdate(ticketId)
        || validRobotTourTicketStartUpdate(ticketId)
        || validRobotTourTicketCompleteUpdate(ticketId);
      allow delete: if false;
    }

    match /tourSessions/{sessionId} {
      allow read: if ownsExisting();
      // Prototype client pairing rule. Production should move pairing to a
      // Cloud Function/server endpoint so robot assignment is authoritative.
      allow create: if validTourSessionCreate(sessionId);
      allow update: if validTourSessionOwnerUpdate();
      allow delete: if false;
    }

    match /questions/{questionId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming()
        && request.resource.data.source == 'app'
        && request.resource.data.reason == 'voice_noise_fallback'
        && request.resource.data.status == 'pending';
      allow update, delete: if false;
    }

    match /photos/{photoId} {
      allow read: if ownsExisting();
      allow create: if ownsIncoming()
        && request.resource.data.type == 'robot_capture';
      allow update: if ownsExisting();
      allow delete: if false;
    }

    match /exhibits/{exhibitId} {
      allow read: if true;
      allow write: if false;
    }

    match /robots/{robotId} {
      allow read: if signedIn();
      allow update: if validRobotPair(robotId)
        || validFinalRobotStart()
        || validRobotRelease();
      allow create, delete: if false;
    }
  }
}
